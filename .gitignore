# =============================================
# ThinkPHP 8 忽略文件
# =============================================

# 系统文件
.DS_Store
Thumbs.db

# 运行时文件
runtime/
*.log
*.cache

# 敏感配置
.env
.env.backup
.env.production

# 编译产物
vendor/
node_modules/
*.min.css
*.min.js

# IDE 配置
.idea/
.vscode/
*.sublime-*
*.swp
*.swo

# 测试覆盖率
/coverage/
.phpunit.result.cache

# 备份文件
*.bak
*~

# =============================================
# H5 端忽略文件
# =============================================

# 缓存文件
*.tmp
.cache/

# 构建产物
dist/
build/

# =============================================
# 数据库相关
# =============================================

# 排除生产数据库配置
# sql/*.sql 目录下的非 init.sql 文件应忽略
sql/*.sql
!sql/init.sql

# =============================================
# 文档相关
# =============================================

# 临时文件
*.tmp
*.draft.*
*~

# =============================================
# Git 保留
# =============================================

# 强制保留 sql 目录
!.gitkeep
